@startuml
title check_partner_contract.py call flow
autonumber

actor Operator as U
participant "check_partner_contract.py" as S
database ".env" as E
participant "ServiceDepositProxy" as P
participant "RatingRouter" as R
participant "Chainlink DON" as C
participant "External API\n(pumpdumpapp)" as A

U -> S: run main(proxy_address, users_csv, amount, timeout, poll)
S -> E: load_dotenv()
S -> E: read PARTNER_PROXY_ADDRESS,\nPARTNER_USERS_CSV,\nTESTING_SENDER_PRIV_KEY
S -> P: at(proxy_address)\nrouter(), MIN_RATING(),\npartnerUsers(beneficiary)

alt beneficiary is not allowed
  S --> U: ValueError("Beneficiary ... is not configured")
else beneficiary allowed
  S -> P: depositFor(beneficiary)\nfrom TESTING_SENDER_PRIV_KEY with ETH
  note right of P
    stores pendingRequests[requestId]:
    (sender, beneficiary, amount)
  end note

  P -> R: requestRating(sender)
  R -> C: _sendRequest(CBOR, subId, gas, donId)
  C -> A: HTTP GET /api/rate/{sender}
  A --> C: {"rate": number}
  C --> R: callback _fulfillRequest(requestId, response/err)
  R -> P: handleRating(requestId, sender, rating)

  alt rating > MIN_RATING
    P -> P: balances[beneficiary] += amount\nsenderRate[sender] = rating\nsenderAccepted[sender] = true
  else rating <= MIN_RATING or error->0
    P --> P: refund sender amount\nsenderRate[sender] = rating\nsenderAccepted[sender] = false
  end

  S -> P: poll pendingRequests(requestId)\nuntil sender == zero
  S -> P: getSenderRateState(sender)\nbalances(user_i)\npartnerUsers(user_i)
  S --> U: print requestId, fulfilled,\nsender rate state, beneficiary balances
end

@enduml
